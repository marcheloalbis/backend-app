<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <title>Reporte de usuarios</title>
    <style>
      table {
        border-collapse: collapse;
        width: 100%;
      }
      
      th, td {
        text-align: left;
        padding: 8px;
      }
      
      tr:nth-child(even) {
        background-color: #f2f2f2;
      }
      
      th {
        background-color: #4CAF50;
        color: white;
      }
      
      h1 {
        color: blue;
      }
    </style>
  </head>
  <body>
    <h1>Listado de usuarios</h1>
    <table>
      <thead>
        <tr>
          <th>Nombre</th>
          <th>Email</th>
        </tr>
      </thead>
      <tbody>
        {{#each data.users}}
        <tr>
          <td>{{name}}</td>
          <td>{{email}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </body>
</html>
